# Copy this file to .env and fill with local secrets.
# .env is loaded by Program.cs at startup and should never be committed.

ConnectionStrings__DevDB=Server=localhost,1433;Database=SchoolSync;User Id=sa;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=True;

Jwt__Key=YOUR_LONG_RANDOM_JWT_SIGNING_KEY
Jwt__Issuer=SchoolSyncAPI
Jwt__Audience=SchoolSyncAPIUsers

Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your-email@gmail.com
Smtp__Password=your-app-password
Smtp__FromEmail=your-email@gmail.com
Smtp__FromName=SchoolSync System
